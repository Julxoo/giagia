				color: var(--ink);
				margin: 0 1px;
				box-shadow: 1.5px 1.5px 0 var(--matcha);
				vertical-align: 1px;
				letter-spacing: 0.02em;
			}

			/* ====== DUO ====== */
			.duo {
				padding: 2.5rem 1rem 3rem;
				max-width: 900px;
				margin: 0 auto;
				contain: layout paint;
			}

			.duo-grid {
				display: grid;
				grid-template-columns: repeat(2, 1fr);
				gap: clamp(1.5rem, 4vw, 3.5rem);
				align-items: start;
				margin-top: 2rem;
			}

			.associe {
				display: flex;
				flex-direction: column;
				align-items: center;
				gap: 1rem;
			}

			.polaroid {
				position: relative;
				background: var(--beige-paper);
				padding: 12px 12px 16px;
				box-shadow:
					5px 5px 0 var(--matcha),
					0 6px 24px rgba(40, 40, 30, 0.1);
				transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
				width: 100%;
				max-width: 320px;
				transform-style: preserve-3d;
			}

			.associe-0 .polaroid { transform: rotate(-2.2deg); --base-rot: -2.2; }
			.associe-1 .polaroid { transform: rotate(1.8deg); --base-rot: 1.8; }

			.frame {
				position: relative;
				background: var(--beige-paper);
				overflow: hidden;
				aspect-ratio: 3 / 4;
				display: block;
			}

			.frame picture,
			.frame img {
				display: block;
				width: 100%;
				height: 100%;
			}

			.frame img {
				object-fit: cover;
				image-orientation: from-image;
				filter: contrast(1.04) saturate(0.88) sepia(0.1);
			}

			.riso-overlay {
				position: absolute;
				inset: 0;
				background: var(--matcha);
				mix-blend-mode: multiply;
				opacity: 0.16;
				transform: translate(3px, 3px);
				pointer-events: none;
			}

			.stamp {
				position: absolute;
				bottom: 10px;
				right: 10px;
				background: var(--matcha);
				color: var(--beige-paper);
				font-family: "Bagel Fat One", sans-serif;
				font-size: 0.78rem;
				padding: 4px 9px;
				border: 2px solid var(--ink);
				transform: rotate(-6deg);
				letter-spacing: 0.04em;
				text-transform: lowercase;
				box-shadow: 2px 2px 0 var(--ink);
			}

			.washi {
				position: absolute;
				top: -12px;
				width: 70px;
				height: 22px;
				background: var(--matcha-tape);
				border: 1px dashed rgba(0, 0, 0, 0.15);
				transform: rotate(-6deg);
			}

			.associe-0 .washi { left: 24px; transform: rotate(-8deg); }
			.associe-1 .washi { right: 22px; transform: rotate(7deg); }

			.caption-card {
				margin-top: 12px;
				padding: 4px 2px 0;
				display: flex;
				flex-direction: column;
				gap: 2px;
				color: var(--ink);
			}

			.caption-card h3 {
				font-size: clamp(1.2rem, 3.5vw, 1.6rem);
				line-height: 1;
				text-transform: lowercase;
				letter-spacing: -0.02em;
			}

			.caption-card .role {
				font-family: "Caveat", cursive;
				font-weight: 500;
				font-size: 1rem;
				color: var(--matcha-deep);
				margin-top: 2px;
				line-height: 1.2;
			}

			.associe .quote {
				font-family: "Caveat", cursive;
				font-weight: 700;
				font-size: clamp(1.2rem, 3.2vw, 1.6rem);
				color: var(--ink);
				text-align: center;
				max-width: 22ch;
				line-height: 1.2;
				transform: rotate(-1.5deg);
			}

			.associe-1 .quote { transform: rotate(1deg); }

			/* ====== FOOTER ====== */
			.footer {
				padding: 2rem 1rem 3rem;
				display: grid;
				place-items: center;
				gap: 1rem;
				contain: layout paint;
			}

			.bubble-tag {
				display: inline-block;
				padding: 0.7rem 1.6rem 0.55rem;
				background: var(--beige-dark);
				border: 2.5px solid var(--ink);
				border-radius: 999px;
				font-size: 1rem;
				letter-spacing: 0.04em;
				box-shadow: 4px 4px 0 var(--matcha);
				transition: transform 0.3s ease, box-shadow 0.3s ease;
				cursor: pointer;
				user-select: none;
			}

			.bubble-tag:active,
			.bubble-tag:hover {
				transform: translate3d(-2px, -2px, 0);
				box-shadow: 6px 6px 0 var(--matcha);
			}

			.footer-counter {
				font-family: "Caveat", cursive;
				font-size: 1rem;
				color: var(--matcha-deep);
				text-align: center;
			}

			.footer-counter span {
				font-family: "Bagel Fat One", sans-serif;
				color: var(--ink);
				margin: 0 3px;
			}

			/* ====== MOBILE ====== */
			@media (max-width: 720px) {
				.hero { min-height: 78svh; }
				/* drop the heavy SVG goo filter on mobile — it kills FPS */
				.bg-blobs > g { filter: none !important; }
				.bg-blobs { opacity: 0.55; mix-blend-mode: normal; }
				.bg-blob { opacity: 0.45; }
				.bb3, .bb4 { display: none; }
				/* drop the grain overlay too — full-screen mix-blend forces compositing per frame */
				.grain { display: none; }
				.duo-grid {
					grid-template-columns: 1fr;
					gap: 2.5rem;
				}
				.polaroid { max-width: 280px; }
				.canvas-wrap canvas { aspect-ratio: 4 / 3; }
				.wisdom-grid { grid-template-columns: 1fr; gap: 1rem; }
				.w-stamp, .w-torn, .w-longue, .w-carnet, .w-post-it, .w-sticker { grid-column: span 1; }
			}

			@media (max-width: 420px) {
				.bb2 { display: none; }
				.canvas-wrap canvas { aspect-ratio: 5 / 4; }
				.hint { font-size: 0.95rem; }
				.riso { font-size: clamp(3.2rem, 17vw, 6rem); }
			}

			/* pause animations on hidden tab */
			.tab-hidden .bg-blob,
			.tab-hidden .baseline,
			.tab-hidden .riso {
				animation-play-state: paused;
			}

			@media (prefers-reduced-motion: reduce) {
				.bg-blob, .riso, .baseline { animation: none !important; }
				.bg-blobs { opacity: 0.4; }
				html { scroll-behavior: auto; }
			}
		</style>
	</body>
</html>
